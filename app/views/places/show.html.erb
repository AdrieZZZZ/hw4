<h1><%= @place["name"] %></h1>

<% if @current_user %>
  <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary mb-3">
    New Entry
  </a>
<% else %>
  <p>Please login to add entries.</p>
<% end %>

<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4 mb-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title"><%= entry["title"] %></h5>

          <h6 class="card-subtitle mb-2 text-muted">
            <%= entry["occurred_on"] %>
          </h6>

          <p class="card-text">
            <%= entry["description"] %>
          </p>
        </div>
      </div>
    </div>
  <% end %>
</div>